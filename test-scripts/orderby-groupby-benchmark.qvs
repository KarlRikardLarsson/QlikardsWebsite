// ============================================================
//  ORDER BY vs GROUP BY — Benchmark Test Script
//  Qlikard | https://qlikard.com
//
//  Tests whether pre-sorting a RESIDENT table with ORDER BY
//  before GROUP BY aggregation improves performance.
//
//  Setup:
//    - 5 million autogenerated rows
//    - 5 iterations per scenario (results are averages)
//    - Tested on Qlik Cloud (RESIDENT loads)
//
//  Scenarios:
//    1A/1B  Low granularity, single field  (Dimension1 ~26 distinct)
//    2A/2B  High granularity, single field (Dimension4 ~unique via Hash128)
//    3A/3B  Low + Low, two fields          (Dimension1 + Dimension2 ~676 combos)
//    4A/4B  Low + High, two fields         (Dimension1 + Dimension4)
// ============================================================


// ── Logging subroutine ──────────────────────────────────────
SUB Sum_GroupBy

// ═════════════════════════════════════════════════════════════════════════════
// TEST 1 — Low granularity, single field (Dimension1: ~26 distinct values)
// ═════════════════════════════════════════════════════════════════════════════

// 1A — GROUP BY only
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Grouped:
LOAD
    Dimension1,
    SUM(Expression1) AS SumExp1
RESIDENT Transactions
GROUP BY Dimension1;
DROP TABLE Tmp_Grouped;
CALL sLog('1A — Low gran, single — GROUP BY only','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));

// 1B — Pre-sort then GROUP BY
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Sorted:
LOAD
    Dimension1,
    Expression1
RESIDENT Transactions
ORDER BY Dimension1;

Tmp_Grouped:
LOAD
    Dimension1,
    SUM(Expression1) AS SumExp1
RESIDENT Tmp_Sorted
GROUP BY Dimension1;
DROP TABLE Tmp_Sorted;
DROP TABLE Tmp_Grouped;
CALL sLog('1B — Low gran, single — Pre-sort + GROUP BY','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));


// ═════════════════════════════════════════════════════════════════════════════
// TEST 2 — High granularity, single field (Dimension4: ~unique per row)
// ═════════════════════════════════════════════════════════════════════════════

// 2A — GROUP BY only
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Grouped:
LOAD
    Dimension4,
    SUM(Expression1) AS SumExp1
RESIDENT Transactions
GROUP BY Dimension4;
DROP TABLE Tmp_Grouped;
CALL sLog('2A — High gran, single — GROUP BY only','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));

// 2B — Pre-sort then GROUP BY
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Sorted:
LOAD
    Dimension4,
    Expression1
RESIDENT Transactions
ORDER BY Dimension4;

Tmp_Grouped:
LOAD
    Dimension4,
    SUM(Expression1) AS SumExp1
RESIDENT Tmp_Sorted
GROUP BY Dimension4;
DROP TABLE Tmp_Sorted;
DROP TABLE Tmp_Grouped;
CALL sLog('2B — High gran, single — Pre-sort + GROUP BY','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));


// ═════════════════════════════════════════════════════════════════════════════
// TEST 3 — Low + Low granularity, two fields (Dimension1 + Dimension2: ~676 combinations)
// ═════════════════════════════════════════════════════════════════════════════

// 3A — GROUP BY only
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Grouped:
LOAD
    Dimension1,
    Dimension2,
    SUM(Expression1) AS SumExp1
RESIDENT Transactions
GROUP BY Dimension1, Dimension2;
DROP TABLE Tmp_Grouped;
CALL sLog('3A — Low+Low, two fields — GROUP BY only','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));

// 3B — Pre-sort then GROUP BY
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Sorted:
LOAD
    Dimension1,
    Dimension2,
    Expression1
RESIDENT Transactions
ORDER BY Dimension1, Dimension2;

Tmp_Grouped:
LOAD
    Dimension1,
    Dimension2,
    SUM(Expression1) AS SumExp1
RESIDENT Tmp_Sorted
GROUP BY Dimension1, Dimension2;
DROP TABLE Tmp_Sorted;
DROP TABLE Tmp_Grouped;
CALL sLog('3B — Low+Low, two fields — Pre-sort + GROUP BY','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));


// ═════════════════════════════════════════════════════════════════════════════
// TEST 4 — Low + High granularity, two fields (Dimension1 + Dimension4)
// ═════════════════════════════════════════════════════════════════════════════

// 4A — GROUP BY only
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Grouped:
LOAD
    Dimension1,
    Dimension4,
    SUM(Expression1) AS SumExp1
RESIDENT Transactions
GROUP BY Dimension1, Dimension4;
DROP TABLE Tmp_Grouped;
CALL sLog('4A — Low+High, two fields — GROUP BY only','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));

// 4B — Pre-sort then GROUP BY
LET vTestStart = timestamp(now(),'hh:mm:ss.fff');
Tmp_Sorted:
LOAD
    Dimension1,
    Dimension4,
    Expression1
RESIDENT Transactions
ORDER BY Dimension1, Dimension4;

Tmp_Grouped:
LOAD
    Dimension1,
    Dimension4,
    SUM(Expression1) AS SumExp1
RESIDENT Tmp_Sorted
GROUP BY Dimension1, Dimension4;
DROP TABLE Tmp_Sorted;
DROP TABLE Tmp_Grouped;
CALL sLog('4B — Low+High, two fields — Pre-sort + GROUP BY','$(vTestStart)',timestamp(now(),'hh:mm:ss.fff'));


END SUB